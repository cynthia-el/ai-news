{
  "name": "ai-news-aggregator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=true prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "sync": "tsx scripts/sync.ts",
    "add": "tsx scripts/manual-add.ts",
    "cf:build": "npx opennextjs-cloudflare build",
    "cf:deploy": "npm run cf:build && npx opennextjs-cloudflare deploy",
    "cf:dev": "npm run cf:build && npx wrangler dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cheerio": "^1.0.0",
    "iconv-lite": "^0.7.2",
    "jose": "^6.2.3",
    "next": "15.5.18",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "wrangler": "^4.93.1"
  }
}
